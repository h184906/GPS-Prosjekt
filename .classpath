<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="src" path="src"/>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry exported="true" kind="lib" path="libs/easygraphics.jar"/>
	<classpathentry exported="true" kind="con" path="org.eclipse.jdt.USER_LIBRARY/JUnit4"/>
	<classpathentry exported="true" kind="con" path="org.eclipse.jdt.USER_LIBRARY/JUnit5.8.1"/>
	<classpathentry kind="output" path="bin"/>
</classpath>